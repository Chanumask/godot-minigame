theme_override_constants/outline_size = 1
text = "Objective\nRoute signal packets to matching sinks and complete delivery targets before overload reaches maximum.\n\nCore Mechanics\nSources emit live blue and red packets. Rotate wires and splitters with Space. Toggle gates to choose output paths. Incorrect routing increases overload.\n\nControls\nArrow Keys or WASD: Move cursor\nSpace: Rotate or toggle selected component\nR: Restart level\nEsc: Pause during gameplay / back in menus"

